{
  "name": "claude-telegram-bot",
  "version": "0.1.0",
  "private": true,
  "description": "Telegram bot that bridges to Claude Code CLI",
  "type": "module",
  "scripts": {
    "start": "tsx src/index.ts",
    "dev": "tsx watch src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "tsc",
    "register-commands": "tsx scripts/register-commands.ts"
  },
  "dependencies": {
    "dotenv": "^16.4.0",
    "grammy": "^1.35.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
