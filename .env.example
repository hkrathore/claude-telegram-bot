# Required
TELEGRAM_BOT_TOKEN=           # From BotFather
ALLOWED_USER_IDS=             # Comma-separated Telegram user IDs

# Optional
DEFAULT_WORKING_DIR=          # Default: current directory
ALLOWED_WORKDIR_BASE=         # Restrict /workdir to this base path (e.g. /home/user/projects)
CLAUDE_MODEL=                 # Default: sonnet (options: sonnet, opus, haiku)
CLAUDE_BINARY=                # Default: claude (from PATH)
SHOW_COST=                    # Set to "true" to show API cost after each response
MAX_BUDGET_USD=               # Cost cap per invocation
SESSION_TTL_HOURS=            # Default: 24
ALLOWED_TOOLS=                # Default: all tools

# Voice transcription (optional, needed for voice messages)
OPENAI_API_KEY=               # OpenAI API key for Whisper transcription

# Webhook (leave empty for polling mode)
WEBHOOK_URL=
WEBHOOK_PORT=                 # Default: 3000
WEBHOOK_SECRET=
